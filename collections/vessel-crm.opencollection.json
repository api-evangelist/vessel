{
  "opencollection": "1.0.0",
  "info": {
    "name": "Vessel CRM API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "vessel-api-token",
      "value": "{{vessel-api-token}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Authentication",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create Link Token",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.vessel.land/link/token"
          },
          "docs": "Creates a link token for initiating the Vessel Link authentication flow. Pass this token to the @vesselapi/react-vessel-link component to open the authentication modal."
        },
        {
          "info": {
            "name": "Exchange Public Token",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.vessel.land/link/exchange",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Exchanges a public token (returned from the Vessel Link UI after successful CRM authentication) for an access token and connection ID."
        }
      ]
    },
    {
      "info": {
        "name": "Contacts",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get All Contacts",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.vessel.land/crm/contacts",
            "params": [
              {
                "name": "accessToken",
                "value": "",
                "type": "query",
                "description": "User connection access token"
              },
              {
                "name": "cursor",
                "value": "",
                "type": "query",
                "description": "Pagination cursor for next page"
              }
            ]
          },
          "docs": "Returns all contacts from the connected CRM."
        },
        {
          "info": {
            "name": "Create a Contact",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.vessel.land/crm/contacts/create",
            "params": [
              {
                "name": "accessToken",
                "value": "",
                "type": "query",
                "description": "User connection access token"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new contact in the connected CRM."
        },
        {
          "info": {
            "name": "Update a Contact",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.vessel.land/crm/contacts/update",
            "params": [
              {
                "name": "accessToken",
                "value": "",
                "type": "query",
                "description": "User connection access token"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Updates an existing contact in the connected CRM."
        }
      ]
    },
